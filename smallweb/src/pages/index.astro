---
import Layout from "../layouts/Layout.astro";
import "../styles/home.css";

const title = "ShowShowShow - Plan your shows, movies & anime";
const description =
  "Keep your shows, movies, and anime in one place, then turn your watchlist into a schedule you'll actually follow.";
const appUrl = import.meta.env.PUBLIC_APP_URL || "https://app.showshowshow.app";
---

<Layout title={title} description={description}>
  <div class="page">
    <header class="nav">
      <div class="nav-container">
        <a class="brand" href="/">ShowShowShow</a>
        <a class="btn primary nav-cta-btn" href={appUrl}>Login</a>
      </div>
    </header>

    <div class="content">
      <main>
        <section class="hero">
          <div class="hero-text reveal" style="animation-delay: 0.05s;">
            <h1>Decide what you're watching before you sit down.</h1>
            <p class="lead">
              Keep your shows, movies, and anime in one place, then turn them
              into a schedule you'll actually follow. No more scrolling to decide.
            </p>
            <div class="hero-actions">
              <a class="btn primary" href={appUrl}>Go to app</a>
            </div>
          </div>
          <div class="hero-media reveal" style="animation-delay: 0.15s;">
            <div class="device-mockup">
              <div class="desktop-frame">
                <div class="desktop-titlebar">
                  <span class="traffic-light red"></span>
                  <span class="traffic-light yellow"></span>
                  <span class="traffic-light green"></span>
                </div>
                <video
                  autoplay
                  muted
                  loop
                  playsinline
                  poster="/images/new_8.png"
                >
                  <source src="/videos/new_30_sec_demo.mp4" type="video/mp4" />
                </video>
              </div>
            </div>
          </div>
        </section>

        <section id="features" class="section reveal" style="animation-delay: 0.05s;">
          <h2 class="section-head">More than a watchlist</h2>
          <div class="metro-tiles">
            <div class="metro-tile purple">
              <h3>Track every episode</h3>
              <p>
                Mark episodes watched, rate what you finish, and pick up right
                where you left off.
              </p>
            </div>
            <div class="metro-tile blue">
              <h3>Lists you can share</h3>
              <p>
                Build ranked lists and export them as clean cards to post
                anywhere.
              </p>
            </div>
            <div class="metro-tile green">
              <h3>Your stats &amp; recap</h3>
              <p>
                See completion, watch time, and a weekly recap of what you
                finished.
              </p>
            </div>
            <div class="metro-tile yellow">
              <h3>No feeds, no noise</h3>
              <p>
                Just your watchlist. No algorithm deciding for you, no social
                pressure.
              </p>
            </div>
          </div>
        </section>
      </main>

      <footer>
        <span>&copy; {new Date().getFullYear()} ShowShowShow</span>
        <span class="footer-pricing">Free for 7 days. $5/month after. No charge during trial.</span>
        <div class="footer-links">
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/contact">Contact</a>
        </div>
        <a
          href="https://www.themoviedb.org/"
          target="_blank"
          rel="noopener noreferrer"
          class="tmdb-attribution"
        >
          <img
            src="https://www.themoviedb.org/assets/2/v4/logos/v2/blue_short-8e7b30f73a4020692ccca9c88bafe5dcb6f8a62a4c6bc55cd9ba82bb2cd95f6c.svg"
            alt="Powered by TMDB"
            height="12"
          />
        </a>
      </footer>
    </div>
  </div>

  <style>
    /* Tighten vertical rhythm so the hero + one section fit in the viewport. */
    .page .hero {
      padding-top: 16px;
      margin-bottom: 32px;
    }
    .content #features.section {
      margin-top: 0;
      margin-bottom: 24px;
    }
    .content footer {
      margin-top: 32px;
    }
    .section-head {
      font-family: "Sora", sans-serif;
      font-size: clamp(1.2rem, 2.5vw, 1.5rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0 0 16px 0;
      text-align: center;
    }
  </style>
</Layout>
